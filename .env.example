# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=securitydrama
DB_USER=securitydrama
DB_PASS=

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# HeyGen
HEYGEN_API_KEY=
# Avatar Group (identity) — looks are picked at random per video for variety.
# Set in the `config` table as `heygen_avatar_group_id`.
# Optional override: set `heygen_avatar_id` in `config` to pin a specific look
# (skips rotation — useful for reproducible testing).

# Seedance / fal.ai
FAL_API_KEY=

# Pexels (b-roll footage for compositing)
PEXELS_API_KEY=

# Missinglettr API
MISSINGLETTR_API_KEY=
MISSINGLETTR_WORKSPACE_ID=

# DigitalOcean Spaces
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_REGION=sgp1
DO_SPACES_BUCKET=securitydrama-media
DO_SPACES_ENDPOINT=https://sgp1.digitaloceanspaces.com
DO_SPACES_CDN_URL=https://securitydrama-media.sgp1.cdn.digitaloceanspaces.com

# YouTube
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# X / Twitter
X_CONSUMER_KEY=
X_CONSUMER_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Reddit
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# Instagram / Facebook / Meta
META_PAGE_ACCESS_TOKEN=
META_IG_USER_ID=
META_PAGE_ID=

# Admin Dashboard
ADMIN_USER=admin
ADMIN_PASS=
