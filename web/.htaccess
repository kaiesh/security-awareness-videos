RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php?$1 [QSA,L]

AuthType Basic
AuthName "Security Drama Admin"
AuthUserFile /etc/apache2/.htpasswd
Require valid-user

<FilesMatch "\.(env|json|lock|md|yml|yaml|xml|sh)$">
    Require all denied
</FilesMatch>

<FilesMatch "^\.">
    Require all denied
</FilesMatch>
